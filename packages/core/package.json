{
  "name": "@neat.is/core",
  "version": "0.4.23",
  "description": "NEAT graph engine: tree-sitter extraction, OTel ingest, REST API",
  "license": "BUSL-1.1",
  "homepage": "https://neat.is",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NEAT-Technologies/Neat.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/cli.cjs": "./dist/cli.cjs",
    "./dist/neatd.cjs": "./dist/neatd.cjs"
  },
  "bin": {
    "neat": "./dist/cli.cjs",
    "neatd": "./dist/neatd.cjs"
  },
  "files": [
    "dist",
    "compat.json",
    "proto"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@neat.is/instrumentation-registry": "^1.0.0",
    "@fastify/cors": "^10.0.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@neat.is/types": "^0.4.23",
    "chokidar": "^4.0.3",
    "fastify": "^5.0.0",
    "graphology": "^0.25.4",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "ignore": "^7.0.0",
    "minimatch": "^10.0.0",
    "protobufjs": "^7.5.6",
    "semver": "^7.6.0",
    "source-map-js": "^1.2.1",
    "smol-toml": "^1.3.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
